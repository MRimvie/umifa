generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_MANAGER
  GRADER
  VIEWER
}

enum SchoolYearStatus {
  INSCRIPTION
  REPARTITION
  EXAMEN
  CLOTURE
}

enum Gender {
  MASCULIN
  FEMININ
}

enum ExamResult {
  ADMIS
  AJOURNE
  EN_ATTENTE
}

model Subject {
  id        String   @id @default(uuid())
  name      String   @unique
  noteMax   Int      @default(20)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subjects")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  
  centerId  String?
  center    ExamCenter? @relation(fields: [centerId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model School {
  id          String   @id @default(uuid())
  name        String   @unique
  address     String?
  phone       String?
  email       String?
  contactName String?
  isActive    Boolean  @default(true)
  
  users       User[]
  candidates  Candidate[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("schools")
}

model SchoolYear {
  id          String           @id @default(uuid())
  year        String           @unique
  startDate   DateTime
  endDate     DateTime
  status      SchoolYearStatus @default(INSCRIPTION)
  isActive    Boolean          @default(true)
  
  candidates  Candidate[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("school_years")
}

model ExamCenter {
  id          String   @id @default(uuid())
  name        String
  nameAr      String?
  address     String
  capacity    Int      @default(0)
  phone       String?
  isActive    Boolean  @default(true)
  
  users       User[]
  candidates  Candidate[]
  grades      Grade[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("exam_centers")
}

model Candidate {
  id              String    @id @default(uuid())
  numeroPV        String?   @unique
  
  firstName       String
  lastName        String
  gender          Gender
  dateOfBirth     DateTime
  placeOfBirth    String
  nationality     String    @default("Française")
  
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id])
  
  schoolYearId    String
  schoolYear      SchoolYear @relation(fields: [schoolYearId], references: [id])
  
  centerId        String?
  center          ExamCenter? @relation(fields: [centerId], references: [id])
  
  grades          Grade[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("candidates")
}

model Grade {
  id              String      @id @default(uuid())
  
  candidateId     String
  candidate       Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  centerId        String?
  center          ExamCenter?  @relation(fields: [centerId], references: [id])
  
  subject         String
  score           Float
  maxScore        Float       @default(20)
  comments        String?
  
  totalScore      Float?
  average         Float?
  result          ExamResult  @default(EN_ATTENTE)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([candidateId, subject])
  @@map("grades")
}
